findByUsername:
SELECT *
FROM UserEntity
WHERE username = :username;

findById:
SELECT *
FROM UserEntity
WHERE id = :id;

insert:
INSERT INTO UserEntity(id, username, password, displayName)
VALUES ?;

update:
UPDATE UserEntity
SET
  password = :password,
  displayName = :displayName
WHERE id = :id;

delete:
DELETE FROM UserEntity WHERE id = :id;
