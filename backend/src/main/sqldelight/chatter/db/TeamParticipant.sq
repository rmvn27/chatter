findByTeamId:
SELECT u.*
FROM UserEntity u
JOIN TeamParticipantEntity tp
ON u.id = tp.userId
WHERE teamId = :teamId;

findParticipantByIdAndTeam:
SELECT *
FROM TeamParticipantEntity
WHERE teamId = :teamId
AND userId = :userId;

create:
INSERT INTO TeamParticipantEntity VALUES ?;

delete:
DELETE FROM TeamParticipantEntity WHERE userId = :userId AND teamId = :teamId;
