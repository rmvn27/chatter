findByTeamId:
SELECT u.*
FROM UserEntity u
JOIN ParticipantEntity tp
ON u.id = tp.userId
WHERE teamId = :teamId;

findParticipantByIdAndTeam:
SELECT *
FROM ParticipantEntity
WHERE teamId = :teamId
AND userId = :userId;

create:
INSERT INTO ParticipantEntity VALUES ?;

delete:
DELETE FROM ParticipantEntity WHERE userId = :userId AND teamId = :teamId;
