findTeamsForParticipant:
SELECT t.*
FROM TeamEntity t
JOIN ParticipantEntity p
ON t.id = p.teamId
WHERE userId = :userId;

findByTeamId:
SELECT u.*
FROM UserEntity u
JOIN ParticipantEntity p
ON u.id = p.userId
WHERE teamId = :teamId;

findParticipantByIdAndTeam:
SELECT *
FROM ParticipantEntity
WHERE teamId = :teamId
AND userId = :userId;

create:
INSERT INTO ParticipantEntity VALUES ?;

delete:
DELETE FROM ParticipantEntity WHERE userId = :userId AND teamId = :teamId;
